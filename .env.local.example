# ---------------------------------------------------------------------------
# Furniture (rental app) — environment variables
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored and must NEVER be committed.
# ---------------------------------------------------------------------------

# --- Supabase -----------------------------------------------------------
# Project URL and keys from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY. Bypasses Row Level Security.
# Never expose to the browser / never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Name of the Supabase Storage bucket that holds product images.
NEXT_PUBLIC_SUPABASE_PRODUCT_BUCKET=product-images

# --- Stripe (added in step 6) -------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Email (order confirmations, via Resend) ----------------------------
# Optional. Without it, confirmation emails are skipped (no crash).
# Get a key at https://resend.com. In test mode you can only send to your
# own account email and use the default from address below.
RESEND_API_KEY=
EMAIL_FROM=Maison <onboarding@resend.dev>

# --- App ----------------------------------------------------------------
# Public base URL of the app (used for Stripe redirects, emails, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
